rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ユーザー自身のプロフィール（親ドキュメント）と同期用サブコレクション
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // サブスク状態は Cloud Functions（Admin SDK）のみが書き換え可能。クライアントは読み取りのみ。
      match /subscription/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      // AI使用量（月次の計測値）も Admin SDK のみが書き換え可能。クライアントは読み取りのみ。
      match /ai_usage/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
        allow write: if false;
      }

      // food_items, training_logs など（subscription / ai_usage 以外）
      match /{subcollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId
          && subcollection != 'subscription'
          && subcollection != 'ai_usage';
      }
    }

    match /community_exercises/{id} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    match /community_foods/{id} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if false;
    }

    // プロモ台帳は Callable（Admin）のみ。クライアントからの直接読書きは禁止。
    match /promo_codes/{code} {
      allow read, write: if false;
    }

    // AI追加クレジットの購入台帳（二重付与防止）は Callable（Admin）のみ。
    match /ai_credit_purchases/{token} {
      allow read, write: if false;
    }

    // Android APK 配布メタデータ。認証済みユーザーのみ読み取り可。書き込みは Admin SDK のみ。
    match /app_releases/android/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
