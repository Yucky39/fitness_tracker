// ソーシャルログイン識別子テンプレート
// このファイルを Secrets.xcconfig にコピーして実際の値を入力すること
// Secrets.xcconfig は .gitignore で除外されているため git には含まれない

// Google Sign-In: Firebase Console で Google を有効化後、
// GoogleService-Info.plist の REVERSED_CLIENT_ID の値を入れること
GOOGLE_REVERSED_CLIENT_ID = REPLACE_WITH_REVERSED_CLIENT_ID

// Meta (Facebook): Meta Developer Console の値を入れること
FACEBOOK_APP_ID = REPLACE_WITH_FACEBOOK_APP_ID
FACEBOOK_CLIENT_TOKEN = REPLACE_WITH_FACEBOOK_CLIENT_TOKEN
